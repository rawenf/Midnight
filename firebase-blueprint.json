{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "handle": { "type": "string" },
        "bio": { "type": "string" },
        "accentColor": { "type": "string" },
        "followersCount": { "type": "integer" },
        "followingCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Pin": {
      "title": "Pin",
      "description": "An image pin uploaded by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "author": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "avatar": { "type": "string" },
            "handle": { "type": "string" }
          }
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "color": { "type": "string" },
        "accentColor": { "type": "string" },
        "archetypes": { "type": "array", "items": { "type": "string" } },
        "colorSpectrum": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "r": { "type": "number" },
              "g": { "type": "number" },
              "b": { "type": "number" },
              "weight": { "type": "number" }
            }
          } 
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "aspectRatio": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "integer" },
        "commentsCount": { "type": "integer" },
        "viewsCount": { "type": "integer" }
      },
      "required": ["userId", "title", "imageUrl", "createdAt", "author"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on a pin",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "parentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "read", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "archival conversation between two users",
      "type": "object",
      "properties": {
        "uids": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "participants": { "type": "object" },
        "unreadCount": { "type": "object" }
      },
      "required": ["uids", "lastMessageAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Archival message in a chat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" }
      },
      "required": ["text", "senderId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/pins/{pinId}": {
      "schema": "Pin",
      "description": "Shared image pins"
    },
    "/pins/{pinId}/likes/{userId}": {
      "schema": { "type": "object", "properties": { "createdAt": { "type": "string" } } },
      "description": "Users who liked this pin"
    },
    "/pins/{pinId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a pin"
    },
    "/users/{userId}/saves/{pinId}": {
      "schema": { "type": "object", "properties": { "savedAt": { "type": "string" } } },
      "description": "Pins saved by a user"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User-specific notifications"
    },
    "/users/{userId}/following/{targetUid}": {
      "schema": { "type": "object", "properties": { "createdAt": { "type": "string" } } },
      "description": "Users followed by this person"
    },
    "/users/{userId}/followers/{targetUid}": {
      "schema": { "type": "object", "properties": { "createdAt": { "type": "string" } } },
      "description": "Users following this person"
    },
    "/users/{userId}/history/{pinId}": {
      "schema": { "type": "object", "properties": { "viewedAt": { "type": "string" } } },
      "description": "Signals recently viewed by this person"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Conversations"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a conversation"
    }
  }
}
